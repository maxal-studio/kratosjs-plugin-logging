{
  "name": "@maxal_studio/kratosjs-plugin-logging",
  "version": "2.0.0",
  "description": "Operation audit logging for KratosJs panels (MongoDB + SQL)",
  "main": "./dist/server/index.js",
  "types": "./dist/server/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/server/index.d.ts",
      "default": "./dist/server/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run clean && tsc -p tsconfig.server.json",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "kratosjs",
    "kratosjs-plugin"
  ],
  "author": "MaxAl",
  "license": "ISC",
  "peerDependencies": {
    "@maxal_studio/kratosjs": "^2.0.0",
    "@mikro-orm/core": "^7.0.0",
    "@mikro-orm/migrations": "^7.0.0"
  },
  "peerDependenciesMeta": {
    "@mikro-orm/migrations": {
      "optional": true
    }
  },
  "devDependencies": {
    "@mikro-orm/migrations": "^7.0.0",
    "typescript": "^5.9.3"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/maxal-studio/kratosjs-plugin-logging.git"
  },
  "bugs": {
    "url": "https://github.com/maxal-studio/kratosjs-plugin-logging/issues"
  },
  "homepage": "https://github.com/maxal-studio/kratosjs-plugin-logging#readme"
}
